{
  "name": "conecta-social-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "start": "expo start --lan",
    "start:clear": "expo start --lan --clear",
    "start:localhost": "expo start --localhost",
    "start:localhost:clear": "expo start --localhost --clear",
    "start:emu": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start",
    "start:emu:clear": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start --clear",
    "start:emulator": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start --clear",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081",
    "metro:kill": "npx --yes kill-port 8081",
    "start:tunnel": "expo start --tunnel",
    "start:phone": "expo start --tunnel --clear",
    "android": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start --android",
    "android:clear": "cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start --clear --android",
    "android:again": "npm run metro:kill && cross-env REACT_NATIVE_PACKAGER_HOSTNAME=10.0.2.2 expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/montserrat": "^0.2.3",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "axios": "^1.13.6",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-embed-instagram": "^0.1.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "victory-native": "^37.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "prettier": "^3.4.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
